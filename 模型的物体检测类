import os
import random
import cv2
from ultralytics import YOLO
from ultralytics.utils.plotting import Annotator


class Detector:
    def __init__(self, device_type=""):
        self.img_size = 640
        self.conf_thres = 0.45
        self.iou_thres = 0.45

        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.weights = os.path.join(base_dir, "best.pt")
        self.device = device_type if device_type else "cpu"

        self.model = YOLO(self.weights)
        self.names = self.model.names
        self.colors = [[random.randint(0, 255) for _ in range(3)] for _ in range(len(self.names))]

        print("模型加载:", self.weights)
        print("类别:", self.names)

    def detect(self, img0):
        obj = []
        if img0 is None:
            return None, []

        img_bgr = cv2.cvtColor(img0, cv2.COLOR_RGB2BGR)

        results = self.model.predict(
            source=img_bgr,
            imgsz=self.img_size,
            conf=self.conf_thres,
            iou=self.iou_thres,
            device=self.device,
            verbose=False
        )

        result = results[0]
        annotator = Annotator(img_bgr.copy(), line_width=2, example=str(self.names))

        if result.boxes is not None and len(result.boxes) > 0:
            boxes_xyxy = result.boxes.xyxy.cpu().numpy()
            boxes_conf = result.boxes.conf.cpu().numpy()
            boxes_cls = result.boxes.cls.cpu().numpy().astype(int)

            for xyxy, conf, cls in zip(boxes_xyxy, boxes_conf, boxes_cls):
                x1, y1, x2, y2 = xyxy.tolist()
                w = x2 - x1
                h = y2 - y1
                cx = x1 + w / 2
                cy = y1 + h / 2

                label = str(self.names[cls])
                annotator.box_label(
                    [x1, y1, x2, y2],
                    f"{label} {float(conf):.2f}",
                    color=tuple(self.colors[cls])
                )

                obj.append({
                    label: {
                        "xywh": [cx, cy, w, h],
                        "conf": round(float(conf), 2)
                    }
                })

        return annotator.result(), obj
